<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Bannister.Views.AttemptsPage"
             Title="Attempts"
             BackgroundColor="#F5F7FC">
    
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            
            <!-- Header -->
            <Label Text="Dragon-Slaying Attempts"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="#12161E"
                   HorizontalOptions="Center"/>
            
            <Label Text="Track your attempts to slay each dragon. Each dragon shows its latest attempt."
                   FontSize="14"
                   TextColor="#5A6273"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   MaximumWidthRequest="500"/>
            
            <!-- Attempts List -->
            <CollectionView x:Name="attemptsList"
                           SelectionMode="None"
                           Margin="0,10,0,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="15"
                               Margin="0,0,0,10"
                               CornerRadius="12"
                               BackgroundColor="White"
                               HasShadow="True"
                               BorderColor="Transparent">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnAttemptTapped"/>
                            </Frame.GestureRecognizers>
                            
                            <Grid RowDefinitions="Auto,Auto,Auto"
                                  ColumnDefinitions="*,Auto">
                                
                                <!-- Dragon Title -->
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding DragonTitle}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#12161E"/>
                                
                                <!-- Status Badge -->
                                <Frame Grid.Row="0" Grid.Column="1"
                                       Padding="8,4"
                                       CornerRadius="12"
                                       BackgroundColor="{Binding StatusColor}"
                                       HasShadow="False">
                                    <Label Text="{Binding StatusText}"
                                           TextColor="White"
                                           FontSize="12"
                                           FontAttributes="Bold"/>
                                </Frame>
                                
                                <!-- Attempt Info -->
                                <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                       Text="{Binding InfoText}"
                                       FontSize="14"
                                       TextColor="#5A6273"
                                       Margin="0,4,0,0"/>
                                
                                <!-- Game -->
                                <Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                       Text="{Binding Game, StringFormat='Game: {0}'}"
                                       FontSize="12"
                                       TextColor="#999"
                                       Margin="0,4,0,0"/>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="40" Spacing="10">
                        <Label Text="No attempts yet."
                               FontSize="16"
                               TextColor="#999"
                               HorizontalOptions="Center"/>
                        <Label Text="Create a dragon first, then start your first attempt!"
                               FontSize="14"
                               TextColor="#AAA"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
            
            <!-- Back Button -->
            <Button Text="Back to Home"
                    Clicked="OnBackClicked"
                    BackgroundColor="#EEE"
                    TextColor="#333"
                    CornerRadius="8"
                    HeightRequest="45"
                    Margin="0,10,0,0"/>
            
        </VerticalStackLayout>
    </ScrollView>
    
</ContentPage>
