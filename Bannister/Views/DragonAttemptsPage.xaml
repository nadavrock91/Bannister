<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Bannister.Views.DragonAttemptsPage"
             Title="Dragon Attempts"
             BackgroundColor="#F5F7FC">
    
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            
            <!-- Header -->
            <Label x:Name="lblDragonTitle"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="#12161E"
                   HorizontalOptions="Center"/>
            
            <!-- Current Attempt Status -->
            <Frame x:Name="currentAttemptFrame"
                   Padding="20"
                   CornerRadius="12"
                   BackgroundColor="White"
                   HasShadow="True"
                   BorderColor="Transparent">
                
                <VerticalStackLayout Spacing="15">
                    <Label x:Name="lblCurrentStatus"
                           FontSize="18"
                           FontAttributes="Bold"/>
                    
                    <Button x:Name="btnAction"
                            HeightRequest="45"
                            CornerRadius="8"/>
                </VerticalStackLayout>
            </Frame>
            
            <!-- Attempt History Header -->
            <Label Text="Attempt History"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="#12161E"
                   Margin="0,10,0,0"/>
            
            <!-- History List -->
            <CollectionView x:Name="historyList"
                           SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="15"
                               Margin="0,0,0,10"
                               CornerRadius="8"
                               BackgroundColor="{Binding BackgroundColor}"
                               BorderColor="Transparent">
                            
                            <Grid RowDefinitions="Auto,Auto"
                                  ColumnDefinitions="*,Auto">
                                
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding AttemptTitle}"
                                       FontSize="16"
                                       FontAttributes="Bold"/>
                                
                                <Label Grid.Row="0" Grid.Column="1"
                                       Text="{Binding StatusIcon}"
                                       FontSize="20"/>
                                
                                <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                       Text="{Binding DurationText}"
                                       FontSize="14"
                                       TextColor="#666"
                                       Margin="0,4,0,0"/>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                
                <CollectionView.EmptyView>
                    <Label Text="No attempts recorded yet"
                           FontSize="14"
                           TextColor="#999"
                           Padding="20"
                           HorizontalOptions="Center"/>
                </CollectionView.EmptyView>
            </CollectionView>
            
            <!-- Back Button -->
            <Button Text="Back to Attempts"
                    Clicked="OnBackClicked"
                    BackgroundColor="#EEE"
                    TextColor="#333"
                    CornerRadius="8"
                    HeightRequest="45"/>
            
        </VerticalStackLayout>
    </ScrollView>
    
</ContentPage>
